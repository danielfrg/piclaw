{
  "name": "piclaw",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.5",
  "scripts": {
    "dev:server": "bun run --cwd packages/server dev",
    "dev:web": "bun run --cwd packages/web dev",
    "build:sdk": "bun run --cwd packages/sdk build",
    "build:web": "bun run --cwd packages/web build",
    "tui": "bun run --cwd packages/tui dev",
    "typecheck": "bun turbo typecheck",
    "db": "bun run --cwd packages/server db",
    "db:studio": "bun run --cwd packages/server db:studio",
    "reset": "rm -rf node_modules packages/*/node_modules packages/server/data packages/server/migration"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@types/bun": "1.3.8",
      "@hono/zod-validator": "0.7.6",
      "@hey-api/openapi-ts": "0.90.10",
      "@hey-api/client-fetch": "0.5.3",
      "@tailwindcss/vite": "4.1.18",
      "@tsconfig/bun": "1.0.10",
      "@types/node": "22.13.14",
      "@types/semver": "7.7.1",
      "hono": "4.11.7",
      "hono-openapi": "1.2.0",
      "pino": "^10.3.1",
      "remeda": "2.33.4",
      "semver": "7.7.3",
      "tailwindcss": "4.1.18",
      "typescript": "5.9.3",
      "ulid": "3.0.2",
      "vite": "7.3.1",
      "zod": "4.3.6"
    }
  },
  "devDependencies": {
    "@tailwindcss/language-server": "0.14.16",
    "@tsconfig/bun": "catalog:",
    "@types/bun": "catalog:",
    "prettier": "3.8.1",
    "turbo": "2.8.1",
    "typescript-language-server": "^5.1.3",
    "vscode-langservers-extracted": "^4.10.0"
  },
  "dependencies": {
    "typescript": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/danielfrg/"
  },
  "license": "MIT",
  "prettier": {
    "semi": false,
    "printWidth": 120
  }
}
