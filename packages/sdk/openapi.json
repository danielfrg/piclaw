{
  "openapi": "3.1.0",
  "info": {
    "title": "Pi Server API",
    "description": "Development documentation",
    "version": "0.1.0"
  },
  "paths": {
    "/api/session": {
      "get": {
        "operationId": "session.list",
        "summary": "List sessions",
        "description": "List all sessions ordered by last update.",
        "responses": {
          "200": {
            "description": "List of sessions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Session"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "session.create",
        "summary": "Create session",
        "description": "Create a new session.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "parentID": {
                    "type": "string",
                    "minLength": 1
                  },
                  "title": {
                    "type": "string",
                    "minLength": 1
                  },
                  "permission": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "permission": {
                          "type": "string"
                        },
                        "pattern": {
                          "type": "string"
                        },
                        "action": {
                          "type": "string",
                          "enum": [
                            "allow",
                            "deny",
                            "ask"
                          ]
                        }
                      },
                      "required": [
                        "permission",
                        "pattern",
                        "action"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Session"
                }
              }
            }
          }
        }
      }
    },
    "/api/session/{sessionID}": {
      "get": {
        "operationId": "session.get",
        "summary": "Get session",
        "description": "Retrieve a session by id.",
        "responses": {
          "200": {
            "description": "Session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Session"
                }
              }
            }
          },
          "404": {
            "description": "Session not found"
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "sessionID",
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true
          }
        ]
      },
      "patch": {
        "operationId": "session.update",
        "summary": "Update session",
        "description": "Update an existing session.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "minLength": 1
                  },
                  "time": {
                    "type": "object",
                    "properties": {
                      "archived": {
                        "type": "number"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Session"
                }
              }
            }
          },
          "404": {
            "description": "Session not found"
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "sessionID",
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true
          }
        ]
      },
      "delete": {
        "operationId": "session.delete",
        "summary": "Delete session",
        "description": "Delete a session.",
        "responses": {
          "200": {
            "description": "Session deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "boolean"
                }
              }
            }
          },
          "404": {
            "description": "Session not found"
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "sessionID",
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true
          }
        ]
      }
    },
    "/api/session/{sessionID}/message": {
      "get": {
        "operationId": "session.messages",
        "summary": "Get session messages",
        "description": "Retrieve all messages in a session.",
        "responses": {
          "200": {
            "description": "List of messages",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MessageWithParts"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Session not found"
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "sessionID",
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true
          }
        ]
      },
      "post": {
        "operationId": "session.prompt",
        "summary": "Send message",
        "description": "Create and send a new message to a session.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "messageID": {
                    "type": "string",
                    "minLength": 1
                  },
                  "model": {
                    "type": "object",
                    "properties": {
                      "providerID": {
                        "type": "string",
                        "minLength": 1
                      },
                      "modelID": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": [
                      "providerID",
                      "modelID"
                    ]
                  },
                  "agent": {
                    "type": "string"
                  },
                  "noReply": {
                    "type": "boolean"
                  },
                  "tools": {
                    "type": "object",
                    "propertyNames": {
                      "type": "string"
                    },
                    "additionalProperties": {
                      "type": "boolean"
                    }
                  },
                  "format": {},
                  "system": {
                    "type": "string"
                  },
                  "variant": {
                    "type": "string"
                  },
                  "parts": {
                    "minItems": 1,
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "text"
                        },
                        "text": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "type",
                        "text"
                      ]
                    }
                  }
                },
                "required": [
                  "parts"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Messages produced by the agent",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MessageWithParts"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "Session not found"
          },
          "409": {
            "description": "Session already running"
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "sessionID",
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true
          }
        ]
      }
    },
    "/api/session/{sessionID}/abort": {
      "post": {
        "operationId": "session.abort",
        "summary": "Abort session",
        "description": "Abort an active session and stop any ongoing processing.",
        "responses": {
          "200": {
            "description": "Aborted session",
            "content": {
              "application/json": {
                "schema": {
                  "type": "boolean"
                }
              }
            }
          },
          "404": {
            "description": "Session not found"
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "sessionID",
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true
          }
        ]
      }
    }
  },
