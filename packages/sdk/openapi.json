{
  "openapi": "3.1.0",
  "info": {
    "title": "Pi Server API",
    "description": "Development documentation",
    "version": "0.1.0"
  },
  "paths": {
    "/api/capabilities": {
      "get": {
        "operationId": "capabilities.list",
        "summary": "Get global capabilities",
        "description": "Get loaded skills and available tools for the agent.",
        "responses": {
          "200": {
            "description": "Agent capabilities",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Capabilities"
                }
              }
            }
          }
        }
      }
    },
    "/api/model": {
      "get": {
        "operationId": "model.list",
        "summary": "List available models",
        "description": "List all models with configured authentication.",
        "responses": {
          "200": {
            "description": "List of available models",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ModelInfo"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/session": {
      "get": {
        "operationId": "session.list",
        "summary": "List sessions",
        "description": "List all sessions ordered by last update.",
        "responses": {
          "200": {
            "description": "List of sessions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Session"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "session.create",
        "summary": "Create session",
        "description": "Create a new session.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "parentID": {
                    "type": "string",
                    "pattern": "^ses_.*"
                  },
                  "title": {
                    "type": "string",
                    "minLength": 1
                  },
                  "permission": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "permission": {
                          "type": "string"
                        },
                        "pattern": {
                          "type": "string"
                        },
                        "action": {
                          "type": "string",
                          "enum": [
                            "allow",
                            "deny",
                            "ask"
                          ]
                        }
                      },
                      "required": [
                        "permission",
                        "pattern",
                        "action"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Session"
                }
              }
            }
          }
        }
      }
    },
    "/api/session/{sessionID}": {
      "get": {
        "operationId": "session.get",
        "summary": "Get session",
        "description": "Retrieve a session by id.",
        "responses": {
          "200": {
            "description": "Session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Session"
                }
              }
            }
          },
          "404": {
            "description": "Session not found"
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "sessionID",
            "schema": {
              "type": "string",
              "pattern": "^ses_.*"
            },
            "required": true
          }
        ]
      },
      "patch": {
        "operationId": "session.update",
        "summary": "Update session",
        "description": "Update an existing session.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "minLength": 1
                  },
                  "time": {
                    "type": "object",
                    "properties": {
                      "archived": {
                        "type": "number"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Session"
                }
              }
            }
          },
          "404": {
            "description": "Session not found"
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "sessionID",
            "schema": {
              "type": "string",
              "pattern": "^ses_.*"
            },
            "required": true
          }
        ]
      },
      "delete": {
        "operationId": "session.delete",
        "summary": "Delete session",
        "description": "Delete a session.",
        "responses": {
          "200": {
            "description": "Session deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "boolean"
                }
              }
            }
          },
          "404": {
            "description": "Session not found"
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "sessionID",
            "schema": {
              "type": "string",
              "pattern": "^ses_.*"
            },
            "required": true
          }
        ]
      }
    },
    "/api/session/{sessionID}/message": {
      "get": {
        "operationId": "session.messages",
        "summary": "Get session messages",
        "description": "Retrieve all messages in a session.",
        "responses": {
          "200": {
            "description": "List of messages",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MessageWithParts"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Session not found"
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "sessionID",
            "schema": {
              "type": "string",
              "pattern": "^ses_.*"
            },
            "required": true
          }
        ]
      },
      "post": {
        "operationId": "session.prompt",
        "summary": "Send message",
        "description": "Create and send a new message to a session.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "messageID": {
                    "type": "string",
                    "pattern": "^msg_.*"
                  },
                  "model": {
                    "type": "object",
                    "properties": {
                      "providerID": {
                        "type": "string",
                        "minLength": 1
                      },
                      "modelID": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": [
                      "providerID",
                      "modelID"
                    ]
                  },
                  "agent": {
                    "type": "string"
                  },
                  "noReply": {
                    "type": "boolean"
                  },
                  "tools": {
                    "type": "object",
                    "propertyNames": {
                      "type": "string"
                    },
                    "additionalProperties": {
                      "type": "boolean"
                    }
                  },
                  "format": {},
                  "system": {
                    "type": "string"
                  },
                  "variant": {
                    "type": "string"
                  },
                  "parts": {
                    "minItems": 1,
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "text"
                        },
                        "text": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "type",
                        "text"
                      ]
                    }
                  }
                },
                "required": [
                  "parts"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Messages produced by the agent",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MessageWithParts"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "Session not found"
          },
          "409": {
            "description": "Session already running"
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "sessionID",
            "schema": {
              "type": "string",
              "pattern": "^ses_.*"
            },
            "required": true
          }
        ]
      }
    },
    "/api/session/{sessionID}/message/stream": {
      "post": {
        "operationId": "session.promptStream",
        "summary": "Send message (streaming)",
        "description": "Send a message and stream the assistant response as SSE events including text deltas, thinking deltas, tool calls, and tool execution updates.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "messageID": {
                    "type": "string",
                    "pattern": "^msg_.*"
                  },
                  "model": {
                    "type": "object",
                    "properties": {
                      "providerID": {
                        "type": "string",
                        "minLength": 1
                      },
                      "modelID": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": [
                      "providerID",
                      "modelID"
                    ]
                  },
                  "agent": {
                    "type": "string"
                  },
                  "noReply": {
                    "type": "boolean"
                  },
                  "tools": {
                    "type": "object",
                    "propertyNames": {
                      "type": "string"
                    },
                    "additionalProperties": {
                      "type": "boolean"
                    }
                  },
                  "format": {},
                  "system": {
                    "type": "string"
                  },
                  "variant": {
                    "type": "string"
                  },
                  "parts": {
                    "minItems": 1,
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "text"
                        },
                        "text": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "type",
                        "text"
                      ]
                    }
                  }
                },
                "required": [
                  "parts"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Event stream",
            "content": {
              "text/event-stream": {
                "schema": {
                  "$ref": "#/components/schemas/StreamEvent"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "Session not found"
          },
          "409": {
            "description": "Session already running"
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "sessionID",
            "schema": {
              "type": "string",
              "pattern": "^ses_.*"
            },
            "required": true
          }
        ]
      }
    },
    "/api/session/{sessionID}/abort": {
      "post": {
        "operationId": "session.abort",
        "summary": "Abort session",
        "description": "Abort an active session and stop any ongoing processing.",
        "responses": {
          "200": {
            "description": "Aborted session",
            "content": {
              "application/json": {
                "schema": {
                  "type": "boolean"
                }
              }
            }
          },
          "404": {
            "description": "Session not found"
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "sessionID",
            "schema": {
              "type": "string",
              "pattern": "^ses_.*"
            },
            "required": true
          }
        ]
      }
    },
    "/api/session/{sessionID}/config": {
      "get": {
        "operationId": "session.config",
        "summary": "Get session config",
        "description": "Get current model and thinking level for a session.",
        "responses": {
          "200": {
            "description": "Session config",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionConfig"
                }
              }
            }
          },
          "404": {
            "description": "Session not found"
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "sessionID",
            "schema": {
              "type": "string",
              "pattern": "^ses_.*"
            },
            "required": true
          }
        ]
      },
      "patch": {
        "operationId": "session.updateConfig",
        "summary": "Update session config",
        "description": "Change model and/or thinking level for a session.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "provider": {
                    "type": "string",
                    "minLength": 1
                  },
                  "modelId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "thinkingLevel": {
                    "type": "string",
                    "enum": [
                      "off",
                      "minimal",
                      "low",
                      "medium",
                      "high",
                      "xhigh"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated session config",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionConfig"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "Session not found"
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "sessionID",
            "schema": {
              "type": "string",
              "pattern": "^ses_.*"
            },
            "required": true
          }
        ]
      }
    },
    "/api/session/{sessionID}/capabilities": {
      "get": {
        "operationId": "session.capabilities",
        "summary": "Get session capabilities",
        "description": "Get loaded skills and tools for a session.",
        "responses": {
          "200": {
            "description": "Session capabilities",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Capabilities"
                }
              }
            }
          },
          "404": {
            "description": "Session not found"
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "sessionID",
            "schema": {
              "type": "string",
              "pattern": "^ses_.*"
            },
            "required": true
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "SkillInfo": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "source": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "description",
          "source"
        ]
      },
      "ToolInfoItem": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "description"
        ]
      },
      "ExtensionInfo": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "path"
        ]
      },
      "Capabilities": {
        "type": "object",
        "properties": {
          "skills": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SkillInfo"
            }
          },
          "tools": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ToolInfoItem"
            }
          },
          "extensions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ExtensionInfo"
            }
          }
        },
        "required": [
          "skills",
          "tools",
          "extensions"
        ]
      },
      "ModelInfo": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
            "minLength": 1
          },
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "api": {
            "type": "string",
            "minLength": 1
          },
          "reasoning": {
            "type": "boolean"
          },
          "input": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "cost": {
            "type": "object",
            "properties": {
              "input": {
                "type": "number"
              },
              "output": {
                "type": "number"
              },
              "cacheRead": {
                "type": "number"
              },
              "cacheWrite": {
                "type": "number"
              }
            },
            "required": [
              "input",
              "output",
              "cacheRead",
              "cacheWrite"
            ]
          },
          "contextWindow": {
            "type": "number"
          },
          "maxTokens": {
            "type": "number"
          }
        },
        "required": [
          "provider",
          "id",
          "name",
          "api",
          "reasoning",
          "input",
          "cost",
          "contextWindow",
          "maxTokens"
        ]
      },
      "Session": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^ses_.*"
          },
          "slug": {
            "type": "string",
            "minLength": 1
          },
          "projectID": {
            "type": "string",
            "minLength": 1
          },
          "directory": {
            "type": "string",
            "minLength": 1
          },
          "parentID": {
            "type": "string",
            "pattern": "^ses_.*"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "time": {
            "type": "object",
            "properties": {
              "created": {
                "type": "number"
              },
              "updated": {
                "type": "number"
              },
              "compacting": {
                "type": "number"
              },
              "archived": {
                "type": "number"
              }
            },
            "required": [
              "created",
              "updated"
            ]
          },
          "permission": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "permission": {
                  "type": "string"
                },
                "pattern": {
                  "type": "string"
                },
                "action": {
                  "type": "string",
                  "enum": [
                    "allow",
                    "deny",
                    "ask"
                  ]
                }
              },
              "required": [
                "permission",
                "pattern",
                "action"
              ]
            }
          }
        },
        "required": [
          "id",
          "slug",
          "projectID",
          "directory",
          "title",
          "version",
          "time"
        ]
      },
      "UserMessage": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^msg_.*"
          },
          "sessionID": {
            "type": "string",
            "pattern": "^ses_.*"
          },
          "role": {
            "type": "string",
            "const": "user"
          },
          "time": {
            "type": "object",
            "properties": {
              "created": {
                "type": "number"
              }
            },
            "required": [
              "created"
            ]
          },
          "format": {},
          "summary": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "body": {
                "type": "string"
              },
              "diffs": {
                "type": "array",
                "items": {}
              }
            }
          },
          "agent": {
            "type": "string",
            "minLength": 1
          },
          "model": {
            "type": "object",
            "properties": {
              "providerID": {
                "type": "string",
                "minLength": 1
              },
              "modelID": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "providerID",
              "modelID"
            ]
          },
          "system": {
            "type": "string"
          },
          "tools": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "boolean"
            }
          },
          "variant": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "sessionID",
          "role",
          "time",
          "agent",
          "model"
        ]
      },
      "AssistantMessage": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^msg_.*"
          },
          "sessionID": {
            "type": "string",
            "pattern": "^ses_.*"
          },
          "role": {
            "type": "string",
            "const": "assistant"
          },
          "time": {
            "type": "object",
            "properties": {
              "created": {
                "type": "number"
              },
              "completed": {
                "type": "number"
              }
            },
            "required": [
              "created"
            ]
          },
          "error": {},
          "parentID": {
            "type": "string",
            "pattern": "^msg_.*"
          },
          "modelID": {
            "type": "string",
            "minLength": 1
          },
          "providerID": {
            "type": "string",
            "minLength": 1
          },
          "mode": {
            "type": "string",
            "minLength": 1
          },
          "agent": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "object",
            "properties": {
              "cwd": {
                "type": "string",
                "minLength": 1
              },
              "root": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "cwd",
              "root"
            ]
          },
          "summary": {
            "type": "boolean"
          },
          "cost": {
            "type": "number"
          },
          "tokens": {
            "type": "object",
            "properties": {
              "total": {
                "type": "number"
              },
              "input": {
                "type": "number"
              },
              "output": {
                "type": "number"
              },
              "reasoning": {
                "type": "number"
              },
              "cache": {
                "type": "object",
                "properties": {
                  "read": {
                    "type": "number"
                  },
                  "write": {
                    "type": "number"
                  }
                },
                "required": [
                  "read",
                  "write"
                ]
              }
            },
            "required": [
              "total",
              "input",
              "output",
              "reasoning",
              "cache"
            ]
          },
          "structured": {},
          "variant": {
            "type": "string"
          },
          "finish": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "sessionID",
          "role",
          "time",
          "parentID",
          "modelID",
          "providerID",
          "mode",
          "agent",
          "path",
          "cost",
          "tokens"
        ]
      },
      "TextPart": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^part_.*"
          },
          "sessionID": {
            "type": "string",
            "pattern": "^ses_.*"
          },
          "messageID": {
            "type": "string",
            "pattern": "^msg_.*"
          },
          "synthetic": {
            "type": "boolean"
